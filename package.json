{
  "name": "mc-config-editor",
  "version": "1.0.0",
  "description": "Minecraft 服务端配置文件可视化编辑工具",
  "main": "./out/main/index.js",
  "author": "MC Config Editor Team",
  "license": "MIT",
  "homepage": "https://github.com/example/mc-config-editor",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "element-plus": "^2.5.6",
    "js-yaml": "^4.1.0",
    "pinia": "^2.1.7",
    "properties-reader": "^2.3.0",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^1.0.2",
    "@electron-toolkit/eslint-config-ts": "^1.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@iconify-json/ep": "^1.1.15",
    "@rushstack/eslint-patch": "^1.7.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.24",
    "@types/properties-reader": "^2.1.3",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.22.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3",
    "unplugin-auto-import": "^0.17.5",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.1.5"
  }
}
